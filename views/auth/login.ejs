<div class="card w-full max-w-md bg-base-100 shadow-xl">
  <div class="card-body">
    <h1 class="text-2xl font-bold text-center">Login</h1>
    <p class="text-center text-base-content/60 mb-4">
      Masuk ke akun TaskGo kamu
    </p>

    <% if (error) { %>
    <div class="alert alert-error mb-4">
      <span><%= error %></span>
    </div>
    <% } %>

    <form action="/login" method="POST" class="space-y-4">
      <div>
        <label class="label">
          <span class="label-text">Email/Username</span>
        </label>
        <input type="text" name="email" class="input input-bordered w-full" placeholder="admin@taskgo.com" />
      </div>

      <div>
        <label class="label">
          <span class="label-text">Password</span>
        </label>
        <input type="password" name="password" class="input input-bordered w-full" placeholder="********" />
      </div>

      <button type="submit" class="btn btn-primary w-full">
        Login
      </button>
    </form>

    <p class="text-center text-sm mt-4">
      Belum punya akun?
      <a href="/register" class="link link-primary">Register</a>
    </p>
  </div>
</div>