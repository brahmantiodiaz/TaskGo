<div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6">
  <div>
    <h1 class="text-3xl font-bold">Manage Items</h1>
    <p class="text-base-content/60">
      Kelola master kategori jasa.
    </p>
  </div>

  <a href="/admin/items/add" class="btn btn-primary">
    Add Item
  </a>
</div>

<div class="card bg-base-100 shadow mb-6">
  <div class="card-body">
    <form action="/admin/items" method="GET" class="flex flex-col md:flex-row gap-3">
      <input type="text" name="search" value="<%= search || '' %>" class="input input-bordered w-full" placeholder="Search item name or description..." />

      <button type="submit" class="btn btn-primary">
        Search
      </button>

      <a href="/admin/items" class="btn btn-ghost">
        Reset
      </a>
    </form>
  </div>
</div>

<div class="overflow-x-auto bg-base-100 rounded-box shadow">
  <table class="table table-zebra">
    <thead>
      <tr>
        <th>No</th>
        <th>Image</th>
        <th>Item</th>
        <th>Status</th>
        <th>Created By</th>
        <th>Created At</th>
        <th class="text-right">Action</th>
      </tr>
    </thead>

    <tbody>
      <% if (items.length === 0) { %>
      <tr>
        <td colspan="7" class="text-center text-base-content/60 py-8">
          No items found
        </td>
      </tr>
      <% } %>

      <% items.forEach((item, index) => { %>
      <tr>
        <td><%= index + 1 %></td>

        <td>
          <div class="avatar">
            <div class="w-14 rounded">
              <img src="<%= item.imageUrl %>" alt="<%= item.name %>">
            </div>
          </div>
        </td>

        <td>
          <div class="font-bold"><%= item.name %></div>
          <div class="text-sm text-base-content/60 line-clamp-1">
            <%= item.description %>
          </div>
        </td>

        <td>
          <% if (item.status === 'active') { %>
          <span class="badge badge-success">active</span>
          <% } else { %>
          <span class="badge badge-error">inactive</span>
          <% } %>
        </td>

        <td>
          <div><%= item.User?.username || '-' %></div>
          <div class="text-sm text-base-content/60">
            <%= item.User?.email || '-' %>
          </div>
        </td>

        <td>
          <%= item.createdAt ? item.createdAt.toLocaleDateString("id-ID") : '-' %>
        </td>

        <td>
          <div class="flex justify-end gap-2">
            <a href="/admin/items/<%= item.id %>" class="btn btn-info btn-xs">
              Detail
            </a>

            <a href="/admin/items/<%= item.id %>/edit" class="btn btn-warning btn-xs">
              Edit
            </a>

            <a href="/admin/items/<%= item.id %>/status" class="btn btn-accent btn-xs">
              Toggle
            </a>

            <a href="/admin/items/<%= item.id %>/delete" class="btn btn-error delete-btn btn-xs" data-title="<%= item.name %>" data-id="<%= item.id %>">
              Delete
            </a>
          </div>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<script>
  const deleteButtons = document.querySelectorAll(".delete-btn");
  deleteButtons.forEach((button) => {
    button.addEventListener("click", function(event) {
      event.preventDefault();

      const title = this.dataset.title;
      const id = this.dataset.id;

      Swal.fire({
        title: "Are you sure delete this data?",
        text: ` "${title}" will deleted permanently`,
        icon: "warning",
        showCancelButton: true,
        confirmButtonText: "Sure!",
        cancelButtonText: "Cancel",
      }).then((result) => {
        if (result.isConfirmed) {
          window.location.href = `/admin/items/${id}/delete`;
        }
      });
    });
  });
</script>