<div class="mb-6">
  <h1 class="text-3xl font-bold">Invoice Detail</h1>
  <p class="text-base-content/60">
    Detail invoice, booking, seller, dan payment.
  </p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <div class="card bg-base-100 shadow">
    <div class="card-body">
      <h2 class="card-title">Invoice Information</h2>

      <div class="overflow-x-auto">
        <table class="table">
          <tr>
            <th class="w-44">Invoice Number</th>
            <td><%= invoice.invoiceNumber %></td>
          </tr>

          <tr>
            <th>Amount</th>
            <td>Rp<%= new Intl.NumberFormat("id-ID").format(invoice.amount) %></td>
          </tr>

          <tr>
            <th>Status</th>
            <td>
              <% if (invoice.status === 'paid') { %>
              <span class="badge badge-success">paid</span>
              <% } else if (invoice.status === 'cancelled') { %>
              <span class="badge badge-error">cancelled</span>
              <% } else { %>
              <span class="badge badge-warning">issued</span>
              <% } %>
            </td>
          </tr>

          <tr>
            <th>Issued At</th>
            <td><%= invoice.issuedAt ? invoice.issuedAt.toLocaleString("id-ID") : '-' %></td>
          </tr>

          <tr>
            <th>Due Date</th>
            <td><%= invoice.dueDate ? invoice.dueDate.toLocaleString("id-ID") : '-' %></td>
          </tr>
        </table>
      </div>
    </div>
  </div>

  <div class="card bg-base-100 shadow">
    <div class="card-body">
      <h2 class="card-title">Booking Information</h2>

      <div class="overflow-x-auto">
        <table class="table">
          <tr>
            <th class="w-44">Booking Code</th>
            <td><%= invoice.Booking?.bookingCode || '-' %></td>
          </tr>

          <tr>
            <th>Booking Date</th>
            <td>
              <%= invoice.Booking?.bookingDate ? invoice.Booking.bookingDate.toLocaleString("id-ID") : '-' %>
            </td>
          </tr>

          <tr>
            <th>Address</th>
            <td><%= invoice.Booking?.address || '-' %></td>
          </tr>

          <tr>
            <th>Booking Status</th>
            <td><%= invoice.Booking?.status || '-' %></td>
          </tr>

          <tr>
            <th>Note</th>
            <td><%= invoice.Booking?.note || '-' %></td>
          </tr>
        </table>
      </div>
    </div>
  </div>

  <div class="card bg-base-100 shadow">
    <div class="card-body">
      <h2 class="card-title">Buyer Information</h2>

      <div class="overflow-x-auto">
        <table class="table">
          <tr>
            <th class="w-44">Username</th>
            <td><%= invoice.Booking?.buyer?.username || '-' %></td>
          </tr>

          <tr>
            <th>Email</th>
            <td><%= invoice.Booking?.buyer?.email || '-' %></td>
          </tr>

          <tr>
            <th>Role</th>
            <td><%= invoice.Booking?.buyer?.role || '-' %></td>
          </tr>
        </table>
      </div>
    </div>
  </div>

  <div class="card bg-base-100 shadow">
    <div class="card-body">
      <h2 class="card-title">Service Information</h2>

      <div class="overflow-x-auto">
        <table class="table">
          <tr>
            <th class="w-44">Service Title</th>
            <td><%= invoice.Booking?.SellerItem?.serviceTitle || '-' %></td>
          </tr>

          <tr>
            <th>Item Category</th>
            <td><%= invoice.Booking?.SellerItem?.Item?.name || '-' %></td>
          </tr>

          <tr>
            <th>Price</th>
            <td>
              Rp<%= new Intl.NumberFormat("id-ID").format(invoice.Booking?.SellerItem?.price || 0) %>
            </td>
          </tr>

          <tr>
            <th>Duration</th>
            <td><%= invoice.Booking?.SellerItem?.duration || '-' %> minutes</td>
          </tr>

          <tr>
            <th>Location</th>
            <td><%= invoice.Booking?.SellerItem?.location || '-' %></td>
          </tr>
        </table>
      </div>
    </div>
  </div>

  <div class="card bg-base-100 shadow">
    <div class="card-body">
      <h2 class="card-title">Seller Information</h2>

      <div class="overflow-x-auto">
        <table class="table">
          <tr>
            <th class="w-44">Seller Name</th>
            <td><%= invoice.issuedBySeller?.UserProfile?.fullName || '-' %></td>
          </tr>

          <tr>
            <th>Phone</th>
            <td><%= invoice.issuedBySeller?.UserProfile?.phoneNumber || '-' %></td>
          </tr>

          <tr>
            <th>Bank</th>
            <td><%= invoice.issuedBySeller?.bankName || '-' %></td>
          </tr>

          <tr>
            <th>Bank Account</th>
            <td><%= invoice.issuedBySeller?.bankAccountNumber || '-' %></td>
          </tr>
        </table>
      </div>
    </div>
  </div>

  <div class="card bg-base-100 shadow">
    <div class="card-body">
      <h2 class="card-title">Payment Information</h2>

      <% if (!invoice.Payment) { %>
      <div class="alert">
        <span>No payment data yet.</span>
      </div>
      <% } else { %>
      <div class="overflow-x-auto">
        <table class="table">
          <tr>
            <th class="w-44">Payment Method</th>
            <td><%= invoice.Payment.paymentMethod %></td>
          </tr>

          <tr>
            <th>Payment Status</th>
            <td>
              <% if (invoice.Payment.paymentStatus === 'paid') { %>
              <span class="badge badge-success">paid</span>
              <% } else if (invoice.Payment.paymentStatus === 'rejected') { %>
              <span class="badge badge-error">rejected</span>
              <% } else if (invoice.Payment.paymentStatus === 'waiting_confirmation') { %>
              <span class="badge badge-warning">waiting confirmation</span>
              <% } else { %>
              <span class="badge badge-ghost">unpaid</span>
              <% } %>
            </td>
          </tr>

          <tr>
            <th>Amount</th>
            <td>Rp<%= new Intl.NumberFormat("id-ID").format(invoice.Payment.amount) %></td>
          </tr>

          <tr>
            <th>Proof Payment</th>
            <td>
              <% if (invoice.Payment.proofPaymentUrl) { %>
              <a href="<%= invoice.Payment.proofPaymentUrl %>" target="_blank" class="link link-primary">
                Open Proof
              </a>
              <% } else { %>
              -
              <% } %>
            </td>
          </tr>

          <tr>
            <th>Paid At</th>
            <td><%= invoice.Payment.paidAt ? invoice.Payment.paidAt.toLocaleString("id-ID") : '-' %></td>
          </tr>

          <tr>
            <th>Confirmed At</th>
            <td><%= invoice.Payment.confirmedAt ? invoice.Payment.confirmedAt.toLocaleString("id-ID") : '-' %></td>
          </tr>
        </table>
      </div>
      <% } %>
    </div>
  </div>
</div>

<div class="mt-6">
  <a href="/admin/invoices" class="btn btn-ghost">Back</a>
</div>