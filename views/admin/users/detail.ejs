<div class="mb-6">
  <h1 class="text-3xl font-bold">User Detail</h1>
  <p class="text-base-content/60">
    Detail akun dan profil user.
  </p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <div class="card bg-base-100 shadow">
    <div class="card-body">
      <h2 class="card-title">Account Information</h2>

      <div class="overflow-x-auto">
        <table class="table">
          <tr>
            <th class="w-40">ID</th>
            <td><%= user.id %></td>
          </tr>

          <tr>
            <th>Username</th>
            <td><%= user.username || '-' %></td>
          </tr>

          <tr>
            <th>Email</th>
            <td><%= user.email %></td>
          </tr>

          <tr>
            <th>Role</th>
            <td>
              <% if (user.role === 'admin') { %>
              <span class="badge badge-primary">admin</span>
              <% } else if (user.role === 'seller') { %>
              <span class="badge badge-success">seller</span>
              <% } else { %>
              <span class="badge badge-info">buyer</span>
              <% } %>
            </td>
          </tr>

          <tr>
            <th>Created At</th>
            <td><%= user.createdAt ? user.createdAt.toLocaleString("id-ID") : '-' %></td>
          </tr>

          <tr>
            <th>Updated At</th>
            <td><%= user.updatedAt ? user.updatedAt.toLocaleString("id-ID") : '-' %></td>
          </tr>
        </table>
      </div>
    </div>
  </div>

  <div class="card bg-base-100 shadow">
    <div class="card-body">
      <h2 class="card-title">Profile Information</h2>

      <% if (!user.UserProfile) { %>
      <div class="alert">
        <span>This user does not have a profile yet.</span>
      </div>
      <% } else { %>
      <div class="overflow-x-auto">
        <table class="table">
          <tr>
            <th class="w-40">Full Name</th>
            <td><%= user.UserProfile.fullName %></td>
          </tr>

          <tr>
            <th>Phone Number</th>
            <td><%= user.UserProfile.phoneNumber %></td>
          </tr>

          <tr>
            <th>Address</th>
            <td><%= user.UserProfile.address || '-' %></td>
          </tr>

          <tr>
            <th>Avatar</th>
            <td>
              <% if (user.UserProfile.avatarUrl) { %>
              <a href="<%= user.UserProfile.avatarUrl %>" target="_blank" class="link link-primary">
                Open Avatar
              </a>
              <% } else { %>
              -
              <% } %>
            </td>
          </tr>
        </table>
      </div>
      <% } %>

      <% if (user.UserProfile?.SellerProfile) { %>
      <div class="divider"></div>

      <h2 class="card-title">Seller Information</h2>

      <div class="overflow-x-auto">
        <table class="table">
          <tr>
            <th class="w-40">Headline</th>
            <td><%= user.UserProfile.SellerProfile.headline %></td>
          </tr>

          <tr>
            <th>Description</th>
            <td><%= user.UserProfile.SellerProfile.description %></td>
          </tr>

          <tr>
            <th>Experience</th>
            <td><%= user.UserProfile.SellerProfile.experienceYear || 0 %> year(s)</td>
          </tr>

          <tr>
            <th>Bank</th>
            <td><%= user.UserProfile.SellerProfile.bankName %></td>
          </tr>

          <tr>
            <th>Account Number</th>
            <td><%= user.UserProfile.SellerProfile.bankAccountNumber %></td>
          </tr>
        </table>
      </div>
      <% } %>
    </div>
  </div>
</div>

<div class="mt-6 flex gap-2">
  <a href="/admin/users" class="btn btn-ghost">Back</a>
  <a href="/admin/users/<%= user.id %>/edit" class="btn btn-warning">Edit</a>
</div>