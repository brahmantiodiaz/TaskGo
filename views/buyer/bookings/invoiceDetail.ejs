<div class="card bg-base-100 shadow mt-6">
  <div class="card-body">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <div>
        <h2 class="card-title">Invoice Information</h2>
        <p class="text-base-content/60">
          Informasi invoice dari seller.
        </p>
      </div>

      <div class="flex flex-wrap items-center gap-2">
        <% if (booking.Invoice.status === "paid") { %>
        <span class="badge badge-success">paid</span>
        <% } else if (booking.Invoice.status === "cancelled") { %>
        <span class="badge badge-error">cancelled</span>
        <% } else { %>
        <span class="badge badge-warning">issued</span>
        <% } %>

        <a href="/buyer/invoices/<%= booking.Invoice.id %>/download" class="btn btn-primary btn-sm">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
          Download Invoice
        </a>
      </div>
    </div>

    <div class="divider"></div>

    <div class="overflow-x-auto">
      <table class="table">
        <tr>
          <th class="w-44">Invoice Number</th>
          <td><%= booking.Invoice.invoiceNumber %></td>
        </tr>

        <tr>
          <th>Amount</th>
          <td>
            <%= booking.Invoice.amountIdr %>
          </td>
        </tr>

        <tr>
          <th>Status</th>
          <td><%= booking.Invoice.status %></td>
        </tr>

        <tr>
          <th>Issued At</th>
          <td>
            <%= booking.Invoice.issuedAt ? booking.Invoice.issuedAt.toLocaleString("id-ID") : "-" %>
          </td>
        </tr>

        <tr>
          <th>Due Date</th>
          <td>
            <%= booking.Invoice.dueDate ? booking.Invoice.dueDate.toLocaleString("id-ID") : "-" %>
          </td>
        </tr>

        <tr>
          <th>Bank Name</th>
          <td><%= booking.SellerItem?.SellerProfile?.bankName || "-" %></td>
        </tr>

        <tr>
          <th>Bank Account</th>
          <td><%= booking.SellerItem?.SellerProfile?.bankAccountNumber || "-" %></td>
        </tr>
      </table>
    </div>

    <% if (booking.Invoice.status !== "paid") { %>
    <div class="card-actions justify-end mt-4">
      <% if (booking.Invoice.Payment?.paymentStatus === 'rejected') { %>
      <a href="/buyer/invoices/<%= booking.Invoice.id %>/pay" class="btn btn-primary">
        Resubmit Payment
      </a>
      <% }else if(!booking.Invoice.Payment) { %>
      <a href="/buyer/invoices/<%= booking.Invoice.id %>/pay" class="btn btn-primary">
        Submit Payment
      </a>
      <% } %>
    </div>
    <% } %>
  </div>
</div>