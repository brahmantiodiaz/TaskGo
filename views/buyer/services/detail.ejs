<div class="mb-6">
  <h1 class="text-3xl font-bold">Service Detail</h1>
  <p class="text-base-content/60">
    Detail layanan dari seller.
  </p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="card bg-base-100 shadow lg:col-span-2">
    <div class="card-body">
      <div class="flex items-start justify-between gap-4">
        <div>
          <h2 class="card-title text-2xl"><%= service.serviceTitle %></h2>
          <p class="text-base-content/60"><%= service.Item?.name || '-' %></p>
        </div>

        <span class="badge badge-success">available</span>
      </div>

      <div class="divider"></div>

      <div class="overflow-x-auto">
        <table class="table">
          <tr>
            <th class="w-44">Description</th>
            <td><%= service.serviceDescription %></td>
          </tr>

          <tr>
            <th>Price</th>
            <td>Rp<%= new Intl.NumberFormat("id-ID").format(service.price) %></td>
          </tr>

          <tr>
            <th>Duration</th>
            <td><%= service.duration %> minutes</td>
          </tr>

          <tr>
            <th>Location</th>
            <td><%= service.location %></td>
          </tr>

          <tr>
            <th>Status</th>
            <td><%= service.status %></td>
          </tr>
        </table>
      </div>
    </div>
  </div>

  <div class="card bg-base-100 shadow">
    <div class="card-body">
      <h2 class="card-title">Seller Information</h2>

      <div class="flex justify-center my-4">
        <div class="avatar">
          <div class="w-28 rounded-full ring ring-primary ring-offset-base-100 ring-offset-2">
            <img src="<%= service.SellerProfile?.UserProfile?.avatarUrl || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(service.SellerProfile?.UserProfile?.fullName || 'Seller') + '&background=random&size=300' %>" alt="<%= service.SellerProfile?.UserProfile?.fullName || 'Seller' %>" />
          </div>
        </div>
      </div>

      <div class="space-y-2">
        <p>
          <span class="font-semibold">Name:</span>
          <%= service.SellerProfile?.UserProfile?.fullName || '-' %>
        </p>

        <p>
          <span class="font-semibold">Phone:</span>
          <%= service.SellerProfile?.UserProfile?.phoneNumber || '-' %>
        </p>

        <p>
          <span class="font-semibold">Headline:</span>
          <%= service.SellerProfile?.headline || '-' %>
        </p>

        <p>
          <span class="font-semibold">Experience:</span>
          <%= service.SellerProfile?.experienceYear || 0 %> year(s)
        </p>
      </div>

      <div class="card-actions justify-end mt-4">
        <a href="/buyer/services" class="btn btn-ghost">Back</a>
        <a href="/buyer/services/<%= service.id %>/book" class="btn btn-primary">
          Book Service
        </a>
      </div>
    </div>
  </div>
</div>