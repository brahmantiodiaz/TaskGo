<div class="mb-6">
  <h1 class="text-3xl font-bold">Invoice Detail</h1>
  <p class="text-base-content/60">
    Detail invoice dan pembayaran.
  </p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <div class="card bg-base-100 shadow">
    <div class="card-body">
      <h2 class="card-title">Invoice Information</h2>

      <div class="overflow-x-auto">
        <table class="table">
          <tr>
            <th class="w-44">Invoice Number</th>
            <td><%= invoice.invoiceNumber %></td>
          </tr>

          <tr>
            <th>Amount</th>
            <td>Rp<%= new Intl.NumberFormat("id-ID").format(invoice.amount) %></td>
          </tr>

          <tr>
            <th>Status</th>
            <td>
              <% if (invoice.status === 'paid') { %>
              <span class="badge badge-success">paid</span>
              <% } else if (invoice.status === 'cancelled') { %>
              <span class="badge badge-error">cancelled</span>
              <% } else { %>
              <span class="badge badge-warning">issued</span>
              <% } %>
            </td>
          </tr>

          <tr>
            <th>Issued At</th>
            <td><%= invoice.issuedAt ? invoice.issuedAt.toLocaleString("id-ID") : '-' %></td>
          </tr>

          <tr>
            <th>Due Date</th>
            <td><%= invoice.dueDate ? invoice.dueDate.toLocaleString("id-ID") : '-' %></td>
          </tr>
        </table>
      </div>
    </div>
  </div>

  <div class="card bg-base-100 shadow">
    <div class="card-body">
      <h2 class="card-title">Booking Information</h2>

      <div class="overflow-x-auto">
        <table class="table">
          <tr>
            <th class="w-44">Booking Code</th>
            <td><%= invoice.Booking?.bookingCode || '-' %></td>
          </tr>

          <tr>
            <th>Buyer</th>
            <td>
              <%= invoice.Booking?.buyer?.username || '-' %>
              <div class="text-sm text-base-content/60">
                <%= invoice.Booking?.buyer?.email || '-' %>
              </div>
            </td>
          </tr>

          <tr>
            <th>Service</th>
            <td><%= invoice.Booking?.SellerItem?.serviceTitle || '-' %></td>
          </tr>

          <tr>
            <th>Category</th>
            <td><%= invoice.Booking?.SellerItem?.Item?.name || '-' %></td>
          </tr>
        </table>
      </div>
    </div>
  </div>

  <div class="card bg-base-100 shadow lg:col-span-2">
    <div class="card-body">
      <h2 class="card-title">Payment Information</h2>

      <% if (!invoice.Payment) { %>
      <div class="alert">
        <span>No payment submitted yet.</span>
      </div>
      <% } else { %>
      <div class="overflow-x-auto">
        <table class="table">
          <tr>
            <th class="w-44">Payment Method</th>
            <td><%= invoice.Payment.paymentMethod %></td>
          </tr>

          <tr>
            <th>Payment Status</th>
            <td><%= invoice.Payment.paymentStatus %></td>
          </tr>

          <tr>
            <th>Amount</th>
            <td>Rp<%= new Intl.NumberFormat("id-ID").format(invoice.Payment.amount) %></td>
          </tr>

          <tr>
            <th>Proof Payment</th>
            <td>
              <% if (invoice.Payment.proofPaymentUrl) { %>
              <a href="<%= invoice.Payment.proofPaymentUrl %>" target="_blank" class="link link-primary">
                Open Proof
              </a>
              <% } else { %>
              -
              <% } %>
            </td>
          </tr>

          <tr>
            <th>Paid At</th>
            <td><%= invoice.Payment.paidAt ? invoice.Payment.paidAt.toLocaleString("id-ID") : '-' %></td>
          </tr>

          <tr>
            <th>Confirmed At</th>
            <td><%= invoice.Payment.confirmedAt ? invoice.Payment.confirmedAt.toLocaleString("id-ID") : '-' %></td>
          </tr>
        </table>
      </div>

      <div class="card-actions justify-end mt-4">
        <a href="/seller/payments/<%= invoice.Payment.id %>" class="btn btn-info">
          View Payment
        </a>
      </div>
      <% } %>
    </div>
  </div>
</div>

<div class="mt-6">
  <a href="/seller/invoices" class="btn btn-ghost">Back</a>
</div>