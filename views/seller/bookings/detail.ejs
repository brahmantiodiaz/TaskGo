<div class="mb-6">
  <h1 class="text-3xl font-bold">Booking Detail</h1>
  <p class="text-base-content/60">
    Detail booking dan tindakan seller.
  </p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <div class="card bg-base-100 shadow">
    <div class="card-body">
      <div class="flex items-start justify-between gap-4">
        <div>
          <h2 class="card-title"><%= booking.bookingCode %></h2>
          <p class="text-base-content/60">Booking Information</p>
        </div>

        <span class="badge badge-outline"><%= booking.status %></span>
      </div>

      <div class="divider"></div>

      <div class="overflow-x-auto">
        <table class="table">
          <tr>
            <th class="w-40">Booking Date</th>
            <td><%= booking.bookingDate ? booking.bookingDate.toLocaleString("id-ID") : '-' %></td>
          </tr>

          <tr>
            <th>Address</th>
            <td><%= booking.address %></td>
          </tr>

          <tr>
            <th>Note</th>
            <td><%= booking.note || '-' %></td>
          </tr>

          <tr>
            <th>Created At</th>
            <td><%= booking.createdAt ? booking.createdAt.toLocaleString("id-ID") : '-' %></td>
          </tr>
        </table>
      </div>
    </div>
  </div>

  <div class="card bg-base-100 shadow">
    <div class="card-body">
      <h2 class="card-title">Buyer & Service</h2>

      <div class="overflow-x-auto">
        <table class="table">
          <tr>
            <th class="w-40">Buyer</th>
            <td>
              <%= booking.buyer?.username || '-' %>
              <div class="text-sm text-base-content/60">
                <%= booking.buyer?.email || '-' %>
              </div>
            </td>
          </tr>

          <tr>
            <th>Service</th>
            <td><%= booking.SellerItem?.serviceTitle || '-' %></td>
          </tr>

          <tr>
            <th>Category</th>
            <td><%= booking.SellerItem?.Item?.name || '-' %></td>
          </tr>

          <tr>
            <th>Price</th>
            <td>Rp<%= new Intl.NumberFormat("id-ID").format(booking.SellerItem?.price || 0) %></td>
          </tr>

          <tr>
            <th>Duration</th>
            <td><%= booking.SellerItem?.duration || '-' %> minutes</td>
          </tr>
        </table>
      </div>
    </div>
  </div>
</div>

<div class="card bg-base-100 shadow mt-6">
  <div class="card-body">
    <h2 class="card-title">Actions</h2>

    <div class="flex flex-wrap gap-2">
      <a href="/seller/bookings" class="btn btn-ghost">Back</a>

      <% if (booking.status === 'pending') { %>
      <form action="/seller/bookings/<%= booking.id %>/approve" method="POST">
        <button type="submit" class="btn btn-success">
          Approve
        </button>
      </form>

      <form action="/seller/bookings/<%= booking.id %>/reject" method="POST">
        <button type="submit" class="btn btn-error">
          Reject
        </button>
      </form>
      <% } %>

      <% if (booking.status === 'approved' || booking.status === 'on_progress') { %>
      <form action="/seller/bookings/<%= booking.id %>/complete" method="POST">
        <button type="submit" class="btn btn-primary">
          Mark as Completed
        </button>
      </form>
      <% } %>

      <% if (booking.status === 'completed' && !booking.Invoice) { %>
      <form action="/seller/bookings/<%= booking.id %>/create-invoice" method="POST">
        <button type="submit" class="btn btn-primary">
          Create Invoice
        </button>
      </form>
      <% } %>

      <% if (booking.Invoice) { %>
      <a href="/seller/invoices/<%= booking.Invoice.id %>" class="btn btn-info">
        View Invoice
      </a>
      <% } %>
    </div>
  </div>
</div>