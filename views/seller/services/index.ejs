<div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6">
  <div>
    <h1 class="text-3xl font-bold">My Services</h1>
    <p class="text-base-content/60">
      Kelola layanan yang kamu tawarkan.
    </p>
  </div>

  <a href="/seller/services/add" class="btn btn-primary">
    Add Service
  </a>
</div>

<div class="card bg-base-100 shadow mb-6">
  <div class="card-body">
    <form action="/seller/services" method="GET" class="grid grid-cols-1 md:grid-cols-4 gap-3">
      <input type="text" name="search" value="<%= search || '' %>" class="input input-bordered md:col-span-2" placeholder="Search service, description, or location..." />

      <select name="status" class="select select-bordered">
        <option value="">All Status</option>
        <% sellerItemStatuses.forEach((sellerItemStatus) => { %>
        <option value="<%= sellerItemStatus %>" <%= status === sellerItemStatus ? 'selected' : '' %>>
          <%= sellerItemStatus %>
        </option>
        <% }) %>
      </select>

      <div class="flex gap-2">
        <button type="submit" class="btn btn-primary flex-1">Filter</button>
        <a href="/seller/services" class="btn btn-ghost">Reset</a>
      </div>
    </form>
  </div>
</div>

<div class="overflow-x-auto bg-base-100 rounded-box shadow">
  <table class="table table-zebra">
    <thead>
      <tr>
        <th>No</th>
        <th>Service</th>
        <th>Category</th>
        <th>Price</th>
        <th>Duration</th>
        <th>Status</th>
        <th class="text-right">Action</th>
      </tr>
    </thead>

    <tbody>
      <% if (services.length === 0) { %>
      <tr>
        <td colspan="7" class="text-center text-base-content/60 py-8">
          No services found
        </td>
      </tr>
      <% } %>

      <% services.forEach((service, index) => { %>
      <tr>
        <td><%= index + 1 %></td>

        <td>
          <div class="font-bold"><%= service.serviceTitle %></div>
          <div class="text-sm text-base-content/60"><%= service.location %></div>
        </td>

        <td>
          <%= service.Item?.name || '-' %>
        </td>

        <td>
          Rp<%= new Intl.NumberFormat("id-ID").format(service.price) %>
        </td>

        <td>
          <%= service.duration %> minutes
        </td>

        <td>
          <% if (service.status === 'available') { %>
          <span class="badge badge-success">available</span>
          <% } else { %>
          <span class="badge badge-error">unavailable</span>
          <% } %>
        </td>

        <td>
          <div class="flex justify-end gap-2">
            <a href="/seller/services/<%= service.id %>" class="btn btn-info btn-xs">Detail</a>
            <a href="/seller/services/<%= service.id %>/edit" class="btn btn-warning btn-xs">Edit</a>
            <a href="/seller/services/<%= service.id %>/status" class="btn btn-accent btn-xs">Toggle</a>
            <a href="/seller/services/<%= service.id %>/delete" class="btn btn-error btn-xs" onclick="return confirm('Delete this service?')">
              Delete
            </a>
          </div>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>