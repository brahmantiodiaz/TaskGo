<!DOCTYPE html>
<html lang="en" data-theme="emerald">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || "Seller" %></title>

  <link href="https://cdn.jsdelivr.net/npm/daisyui@5" rel="stylesheet" type="text/css" />
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-base-200 min-h-screen">
  <div class="drawer lg:drawer-open">
    <input id="seller-drawer" type="checkbox" class="drawer-toggle" />

    <div class="drawer-content flex flex-col">
      <div class="navbar bg-base-100 shadow-sm lg:hidden">
        <div class="flex-none">
          <label for="seller-drawer" class="btn btn-square btn-ghost">
            ☰
          </label>
        </div>
        <div class="flex-1 font-bold">Seller Panel</div>
      </div>

      <main class="p-6">
        <%- body %>
      </main>
    </div>

    <div class="drawer-side">
      <label for="seller-drawer" class="drawer-overlay"></label>

      <aside class="menu p-4 w-72 min-h-full bg-base-100 text-base-content">
        <h1 class="text-2xl font-bold text-primary mb-6">TaskGo Seller</h1>
        <li>
          <a href="/seller" class="<%= currentPath === '/seller' ? 'active' : '' %>">
            Dashboard
          </a>
        </li>

        <li>
          <a href="/seller/profile" class="<%= currentPath.startsWith('/seller/profile') ? 'active' : '' %>">
            Profile
          </a>
        </li>

        <li>
          <a href="/seller/services" class="<%= currentPath.startsWith('/seller/services') ? 'active' : '' %>">
            My Services
          </a>
        </li>

        <li>
          <a href="/seller/bookings" class="<%= currentPath.startsWith('/seller/bookings') ? 'active' : '' %>">
            Bookings
          </a>
        </li>

        <li>
          <a href="/seller/invoices" class="<%= currentPath.startsWith('/seller/invoices') ? 'active' : '' %>">
            Invoices
          </a>
        </li>

        <li>
          <a href="/seller/payments" class="<%= currentPath.startsWith('/seller/payments') ? 'active' : '' %>">
            Payments
          </a>
        </li>

        <div class="divider"></div>

        <li>
          <a href="/logout" class="text-error">Logout</a>
        </li>
      </aside>
    </div>
  </div>
</body>

</html>