<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || "Buyer" %></title>

  <link href="https://cdn.jsdelivr.net/npm/daisyui@5" rel="stylesheet" type="text/css" />
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-base-200 min-h-screen">
  <div class="navbar bg-base-100 shadow-sm px-8">
    <div class="flex-1">
      <a href="/buyer" class="text-xl font-bold text-primary">TaskGo Buyer</a>
    </div>

    <div class="flex-none">
      <ul class="menu menu-horizontal px-1">
        <li>
          <a href="/buyer" class="<%= currentPath === '/buyer' ? 'active' : '' %>">
            Dashboard
          </a>
        </li>

        <li>
          <a href="/buyer/profile" class="<%= currentPath.startsWith('/buyer/profile') ? 'active' : '' %>">
            Profile
          </a>
        </li>

        <li>
          <a href="/buyer/services" class="<%= currentPath.startsWith('/buyer/services') ? 'active' : '' %>">
            Explore Services
          </a>
        </li>

        <li>
          <a href="/buyer/bookings" class="<%= currentPath.startsWith('/buyer/bookings') ? 'active' : '' %>">
            My Bookings
          </a>
        </li>

        <li>
          <a href="/buyer/invoices" class="<%= currentPath.startsWith('/buyer/invoices') ? 'active' : '' %>">
            Invoices
          </a>
        </li>

        <li>
          <a href="/buyer/payments" class="<%= currentPath.startsWith('/buyer/payments') ? 'active' : '' %>">
            Payments
          </a>
        </li>

        <li>
          <a href="/logout" class="text-error">Logout</a>
        </li>
      </ul>
    </div>
  </div>

  <main class="p-6">
    <%- body %>
  </main>
</body>

</html>