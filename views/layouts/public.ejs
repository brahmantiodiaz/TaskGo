<!DOCTYPE html>
<html lang="en" data-theme="corporate">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || "TaskGo" %></title>

  <link href="https://cdn.jsdelivr.net/npm/daisyui@5" rel="stylesheet" type="text/css" />
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-base-100 min-h-screen">
  <div class="navbar bg-base-100 shadow-sm px-8">
    <div class="flex-1">
      <a href="/" class="text-xl font-bold text-primary">TaskGo</a>
    </div>

    <div class="flex-none gap-2">
      <a href="/login" class="btn btn-ghost">Login</a>
      <a href="/register" class="btn btn-primary">Register</a>
    </div>
  </div>

  <main>
    <%- body %>
  </main>

  <footer class="footer footer-center bg-base-200 text-base-content p-6 mt-20">
    <aside>
      <p>© <%= new Date().getFullYear() %> TaskGo. All rights reserved.</p>
    </aside>
  </footer>
</body>

</html>